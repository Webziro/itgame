// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  WAGER
  WIN
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  role            Role      @default(USER)
  walletBalance   Float     @default(0)
  bonusBalance    Float     @default(0)
  bonusWagered    Float     @default(0) // Track how much of the bonus has been used
  isPwaInstalled  Boolean   @default(false)
  streak          Int       @default(0)
  lastLogin       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  transactions    Transaction[]
  poolEntries     Participant[]
  duels           DuelParticipant[]
  accounts        Account[]
  sessions        Session[]
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Question {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  content       String
  options       String[]
  answerIndex   Int
  difficulty    Difficulty
  category      String     @default("General")
  createdAt     DateTime   @default(now())
}

model Transaction {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  userId        String            @db.ObjectId
  user          User              @relation(fields: [userId], references: [id])
  type          TransactionType
  amount        Float
  status        TransactionStatus @default(PENDING)
  providerRef   String?           @unique
  description   String?
  metadata      Json?
  createdAt     DateTime          @default(now())
}

model Pool {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  startTime     DateTime
  entryFee      Float
  totalStaked   Float         @default(0)
  status        String        @default("UPCOMING") // UPCOMING, LIVE, COMPLETED
  participants  Participant[]
  createdAt     DateTime      @default(now())
}

model Participant {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  poolId        String    @db.ObjectId
  pool          Pool      @relation(fields: [poolId], references: [id])
  userId        String    @db.ObjectId
  user          User      @relation(fields: [userId], references: [id])
  score         Int       @default(0)
  timeTaken     Float     @default(0) // Time-weighted score factor
  joinedAt      DateTime  @default(now())
}

model Duel {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  wager         Float
  status        DuelStatus        @default(WAITING)
  participants  DuelParticipant[]
  questions     String[]          @db.ObjectId // IDs of questions used
  winnerId      String?           @db.ObjectId
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model DuelParticipant {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  duelId        String    @db.ObjectId
  duel          Duel      @relation(fields: [duelId], references: [id])
  userId        String    @db.ObjectId
  user          User      @relation(fields: [userId], references: [id])
  score         Int       @default(0)
  timeTaken     Float     @default(0)
  hasFinished   Boolean   @default(false)
  joinedAt      DateTime  @default(now())
}

enum DuelStatus {
  WAITING
  ACTIVE
  FINISHED
  CANCELLED
}

model IpAttempt {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  ip            String    @unique
  attempts      Int       @default(0)
  lastAttempt   DateTime  @default(now())
  isBlocked     Boolean   @default(false)
  blockedUntil  DateTime?
}
